{
  "name": "jja",
  "type": "module",
  "version": "2.3.15",
  "private": true,
  "description": "一些在终端的执行动作 🥜",
  "scripts": {
    "beautify": "pnpm run eslint && pnpm run prettier",
    "run": "pnpm run dev run",
    "build": "jja rm dist && rollup --config rollup.config.js && pnpm run clean:package",
    "clean:package": "node scripts/clean-package-json.js",
    "eslint": "npx eslint src",
    "diff": "pnpm run build && node ./dist/bin.mjs pkg --diff=淘宝",
    "dev": "jja rm dist && pnpm run build && jja_dev=all node dist/bin.mjs github",
    "prettier": "prettier --write .",
    "push:version": "gvv",
    "push": "gvv",
    "test": "lint-staged&&jest --coverage",
    "vjj": "vjj",
    "prepublishOnly": "pjj",
    "prepare": "husky"
  },
  "license": "MIT",
  "lint-staged": {
    "**/*.{js,ts,tsx,jex,md,mdx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@color-pen/static": "^1.0.0",
    "@qqi/copy-text": "^1.0.5",
    "@qqi/log": "^0.1.0",
    "a-command": "^2.3.13",
    "a-js-tools": "^1.0.8",
    "a-node-tools": "^4.2.16",
    "a-type-of-js": "^1.0.5",
    "color-pen": "^2.0.12",
    "colored-table": "^0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@qqi/check-version": "^1.0.4",
    "@qqi/dev": "^0.1.0",
    "@qqi/rollup-external": "^1.0.9",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.14",
    "codecov": "^3.8.3",
    "coveralls": "^3.1.1",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.7",
    "eslint-plugin-jsdoc": "^52.0.1",
    "globals": "^16.3.0",
    "gvv": "^0.1.3",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jest-junit": "^16.0.0",
    "jja": "^2.3.11",
    "lint-staged": "^16.1.2",
    "pjj": "^1.0.2",
    "prettier": "^3.6.2",
    "rollup": "^4.45.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.5.0",
    "ts-jest": "^29.3.4",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vjj": "^1.0.8"
  }
}
